PORT=3001
CORS_ORIGIN=http://localhost:3000
DB_PATH=./data/articles.db

# VAPID keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# 爬取间隔（分钟）
SCRAPE_INTERVAL=30

# 贴吧爬取配置
TIEBA_KEYWORDS=ts,cd,第三性,伪娘,药娘,trans,mtf,ftm
TIEBA_MAX_POSTS=50

# 微博爬取配置
WEIBO_KEYWORDS=ts,cd,第三性,伪娘,药娘
WEIBO_MAX_POSTS=50

# RSS 源
RSS_FEEDS=https://rsshub.app/weibo/search/第三性,https://rsshub.app/weibo/search/伪娘
